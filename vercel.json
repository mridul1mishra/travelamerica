{
  "crons": [
    {
      "path": "/api/drip",
      "schedule": "0 8 * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "master": true
    },
    "deploymentSuffix": {
      "master": ""
    },
    "deployments": {
      "preview": false
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.travelsamericas.com/$1",
      "has": [
        {
          "type": "host",
          "value": "www.travelamerica.work"
        }
      ],
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "destination": "https://www.travelsamericas.com/$1",
      "has": [
        {
          "type": "host",
          "value": "travelamerica.work"
        }
      ],
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "destination": "https://www.travelsamericas.com/$1",
      "has": [
        {
          "type": "host",
          "value": ":subdomain.travelamerica.work"
        }
      ],
      "statusCode": 308
    },
